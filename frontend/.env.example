# PICT Guard Frontend Environment Configuration
# Copy this file to .env.local and fill in your actual values

# ============ API CONFIGURATION ============
# Backend API URL
# For development: http://localhost:8001
# For production: https://your-backend-domain.com
REACT_APP_BACKEND_URL=http://localhost:8001

# ============ APPLICATION SETTINGS ============
# Application name
REACT_APP_NAME=PICT Guard

# Application version
REACT_APP_VERSION=2.0.0

# ============ FEATURE FLAGS ============
# Enable/disable features
REACT_APP_ENABLE_EMAIL_NOTIFICATIONS=true
REACT_APP_ENABLE_QR_DOWNLOAD=true
REACT_APP_ENABLE_BULK_UPLOAD=true

# ============ UI CONFIGURATION ============
# Theme mode: light, dark, auto
REACT_APP_THEME_MODE=light

# ============ SECURITY ============
# Token storage: localStorage, sessionStorage
REACT_APP_TOKEN_STORAGE=localStorage

# Token expiration time in minutes
REACT_APP_TOKEN_EXPIRY=60

# ============ LOGGING ============
# Enable debug logging
REACT_APP_DEBUG_MODE=false

# ============ FILE UPLOAD ============
# Maximum file size for bulk upload (in MB)
REACT_APP_MAX_FILE_SIZE=5

# Allowed file extensions for bulk upload
REACT_APP_ALLOWED_FILE_TYPES=.xlsx,.xls

# ============ PERFORMANCE ============
# Enable code splitting and lazy loading
REACT_APP_LAZY_LOADING=true

# API request timeout (in milliseconds)
REACT_APP_API_TIMEOUT=30000
