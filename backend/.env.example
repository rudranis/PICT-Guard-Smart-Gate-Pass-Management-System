# PICT Guard Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ============ MONGODB CONFIGURATION ============
# MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/
# Or for local: mongodb://localhost:27017/
MONGO_URL=mongodb://localhost:27017/

# Database name
DB_NAME=pict_guard

# ============ EMAIL CONFIGURATION (Gmail SMTP) ============
# Gmail sender email address
SENDER_EMAIL=your-email@gmail.com

# Gmail app-specific password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_PASSWORD=your-16-char-app-password

# ============ CORS CONFIGURATION ============
# Comma-separated list of allowed origins for CORS
# Examples: http://localhost:3000, https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ============ SERVER CONFIGURATION ============
# Backend server host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# ============ JWT/SECURITY ============
# Secret key for JWT token generation (use a strong random string)
SECRET_KEY=your-super-secret-key-change-this-in-production

# ============ RESEND EMAIL SERVICE (Optional) ============
# If using Resend service instead of Gmail
# Sign up at: https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# ============ ENVIRONMENT ============
# Environment: development, staging, production
ENVIRONMENT=development

# ============ LOGGING ============
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
